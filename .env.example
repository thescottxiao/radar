# LLM
ANTHROPIC_API_KEY=

# Google OAuth (per-tenant tokens stored in DB, these are app-level credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Pub/Sub (Gmail push notifications)
GOOGLE_CLOUD_PROJECT=
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_SUBSCRIPTION=

# WhatsApp Business API (via Twilio or Meta Cloud API)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/radar

# Encryption (for OAuth refresh tokens at rest)
TOKEN_ENCRYPTION_KEY=

# Forward-to email ingestion
FORWARD_EMAIL_DOMAIN=
